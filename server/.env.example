# Copy this file to "server/.env" and fill in your real Clerk SECRET key.
# The .env file is git-ignored; this .example is committed as documentation.
#
# SECURITY: the secret key is sensitive — it can mint/verify sessions. Keep it
# server-side only; never put it in the client or in a commit.
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Required: the same publishable key the client uses. Clerk's backend needs it
# to resolve your instance when verifying tokens. Safe to expose (it's public).
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Database: leave both UNSET for local development — the app falls back to a
# local SQLite file (server/data/finance.db). In production, set both to use
# the hosted Turso database. The auth token is a secret (like a password).
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_token_here
